# ============================================
# MikroTik Hotspot Manager — Environment Config
# ============================================

# MongoDB Atlas Connection String
# For Vercel: use MongoDB Atlas (mongodb+srv://...)
# For local dev: mongodb://localhost:27017/hotspot-manager
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/hotspot-manager?retryWrites=true&w=majority

# MikroTik Router Connection
# For Vercel: use your PUBLIC IP or DDNS hostname (NOT 192.168.x.x)
# Forward port 8728 on your router's WAN interface
# Restrict access with MikroTik firewall rules
MIKROTIK_HOST=your-public-ip-or-ddns.example.com
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=your_router_password
MIKROTIK_MODE=usermanager

# NextAuth / JWT
# Generate a strong secret: openssl rand -hex 32
NEXTAUTH_SECRET=generate_a_strong_random_secret_here

# For Vercel: set to your deployed URL
# For local dev: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Paystack Payment
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key

# Admin Account (used by seed script)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMeNow123!

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
